# ====================================================================
# .env.example — copie para .env (modo Docker) ou .env.local (híbrido)
# ====================================================================
#
# Existem DOIS modos de rodar o OpenM:
#
#  1. FULL DOCKER  — `docker compose up` (db+neo4j+flask tudo container)
#     → use .env.docker (já preparado) ou renomeie este arquivo para .env
#     → DATABASE_URL aponta para `postgres` e NEO4J_URI para `neo4j`
#
#  2. HÍBRIDO      — db+neo4j no Docker, Flask rodando LOCAL
#     → use .env.local (já preparado)
#     → DATABASE_URL aponta para `localhost`, NEO4J_URI para `localhost`
#     → mais rápido, hot-reload, debug nativo
#     → comandos: make db-up && make api
#

# Flask
FLASK_APP=openm/app.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL
# MODO DOCKER:    postgresql://openm:openm123@postgres:5432/openm
# MODO HÍBRIDO:   postgresql://openm:openm123@localhost:5432/openm
DATABASE_URL=postgresql://openm:openm123@postgres:5432/openm

# Neo4j
# MODO DOCKER:    bolt://neo4j:7687
# MODO HÍBRIDO:   bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=openm123

# Rate limiting (Redis opcional; memória se ausente)
# Storage memory:// é single-process — em multi-worker (gunicorn -w N),
# cada worker tem seu próprio contador. Para multi-process, use Redis:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# === Rate limiting per service (Issue #89) ===
# Limites por service externo. Formato: N/period
# (period: second|minute|hour|day|month|year).
# Cada user tem seu próprio contador (key = "u<user_id>:<service_name>").
# Admins são isentos (exempt_when=g.user.role=="admin").
# Storage memory:// NÃO compartilha estado entre processos — em prod
# multi-worker, defina RATELIMIT_STORAGE_URI=redis://... acima.
OPENM_RATE_LIMIT_SHODAN=10/hour
OPENM_RATE_LIMIT_VIRUSTOTAL=4/minute
OPENM_RATE_LIMIT_HUNTER=10/day
OPENM_RATE_LIMIT_HIBP=10/minute
OPENM_RATE_LIMIT_URLSCAN=100/day
OPENM_RATE_LIMIT_ABUSEIPDB=1000/day
OPENM_RATE_LIMIT_SECURITYTRAILS=5/day
OPENM_RATE_LIMIT_EMAILREP=100/day
OPENM_RATE_LIMIT_THREAT_INTEL=10/hour
OPENM_RATE_LIMIT_INTERNAL=100/hour

# API Keys (preencher no painel do OpenM ou aqui para seed)
# EMAILREP_API_KEY=
# HIBP_API_KEY=
# ABSTRACTAPI_EMAIL_KEY=
# SHODAN_API_KEY=

# === Auth / JWT ===
# Se vazio, reutiliza SECRET_KEY. Defina um valor forte em produção.
# JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=openm
JWT_AUDIENCE=openm-api

# === Audit log (issue #4) ===
# Retenção em dias para o comando `flask audit purge`. Default: 90.
# AUDIT_LOG_RETENTION_DAYS=90

# Habilita POST /api/auth/register. Default: false (fechado em produção).
# Para o primeiro deploy/local, defina ALLOW_REGISTRATION=true.
ALLOW_REGISTRATION=false
