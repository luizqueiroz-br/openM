# ====================================================================
# .env.example — copie para .env (modo Docker) ou .env.local (híbrido)
# ====================================================================
#
# Existem DOIS modos de rodar o OpenM:
#
#  1. FULL DOCKER  — `docker compose up` (db+neo4j+flask tudo container)
#     → use .env.docker (já preparado) ou renomeie este arquivo para .env
#     → DATABASE_URL aponta para `postgres` e NEO4J_URI para `neo4j`
#
#  2. HÍBRIDO      — db+neo4j no Docker, Flask rodando LOCAL
#     → use .env.local (já preparado)
#     → DATABASE_URL aponta para `localhost`, NEO4J_URI para `localhost`
#     → mais rápido, hot-reload, debug nativo
#     → comandos: make db-up && make api
#

# Flask
FLASK_APP=openm/app.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL
# MODO DOCKER:    postgresql://openm:openm123@postgres:5432/openm
# MODO HÍBRIDO:   postgresql://openm:openm123@localhost:5432/openm
DATABASE_URL=postgresql://openm:openm123@postgres:5432/openm

# Neo4j
# MODO DOCKER:    bolt://neo4j:7687
# MODO HÍBRIDO:   bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=openm123

# Rate limiting (Redis opcional; memória se ausente)
RATELIMIT_STORAGE_URI=memory://

# API Keys (preencher no painel do OpenM ou aqui para seed)
# EMAILREP_API_KEY=
# HIBP_API_KEY=
# ABSTRACTAPI_EMAIL_KEY=

# === Auth / JWT ===
# Se vazio, reutiliza SECRET_KEY. Defina um valor forte em produção.
# JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=openm
JWT_AUDIENCE=openm-api

# Habilita POST /api/auth/register. Default: false (fechado em produção).
# Para o primeiro deploy/local, defina ALLOW_REGISTRATION=true.
ALLOW_REGISTRATION=false
